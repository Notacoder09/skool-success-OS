# --- App ---
# Public origin for absolute URLs (magic-link callbacks, emails, etc.)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# --- Auth (NextAuth/Auth.js) ---
# 32+ random bytes, base64. Generate with: openssl rand -base64 32
AUTH_SECRET=

# --- Database (Neon Postgres) ---
# HTTP/serverless driver string used by app code at request time.
DATABASE_URL=
# Pooled connection used by drizzle-kit migrations and cron jobs.
DATABASE_URL_POOLED=

# --- Email (Resend) ---
RESEND_API_KEY=
# From address used for magic links + flashcard sends + weekly reports.
RESEND_FROM="Skool Success OS <hello@skoolsuccess.os>"

# --- Skool credential encryption (ADR-0003) ---
# 32 bytes random, base64. Generate with: openssl rand -base64 32
# Rotation supported via key versioning; never log plaintext.
SKOOL_CREDENTIALS_ENCRYPTION_KEY=
SKOOL_CREDENTIALS_KEY_VERSION=1

# --- AI ---
ANTHROPIC_API_KEY=
# Whisper (OpenAI). Only used when creator opts in AND has quota (ADR-0005).
OPENAI_API_KEY=
