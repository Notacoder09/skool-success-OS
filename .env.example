# --- App ---
# Public origin for absolute URLs (magic-link callbacks, emails, etc.)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# --- Auth (NextAuth/Auth.js) ---
# 32+ random bytes, base64. Generate with: openssl rand -base64 32
AUTH_SECRET=

# --- Database (Neon Postgres) ---
# HTTP/serverless driver string used by app code at request time.
DATABASE_URL=
# Pooled connection used by drizzle-kit migrations and cron jobs.
DATABASE_URL_POOLED=

# --- Email (Resend) ---
RESEND_API_KEY=
# From address used for magic links + flashcard sends + weekly reports.
RESEND_FROM="Skool Success OS <hello@skoolsuccess.os>"

# --- Skool credential encryption (ADR-0003) ---
# 32 bytes random, base64. Generate with: openssl rand -base64 32
# Rotation supported via key versioning; never log plaintext.
SKOOL_CREDENTIALS_ENCRYPTION_KEY=
SKOOL_CREDENTIALS_KEY_VERSION=

# --- AI ---
# Used by Day 6 Drop-Off Map insight generation (ADR-0009). When this
# key is unset the app uses a deterministic rule-based fallback so the
# UI is never blank — the upgrade with a real key is voice quality.
ANTHROPIC_API_KEY=
# Whisper (OpenAI). Only used when creator opts in AND has quota (ADR-0005).
OPENAI_API_KEY=

# --- Beta (Day 14) ---
# Leave empty or omit for open sign-ups. Otherwise comma-separated emails
# that may request magic links (invite-only cohort). Values may be wrapped
# in ASCII quotes (handled by the parser).
BETA_INVITE_EMAILS=

# Email shown on /beta waitlist ("How to join"). Override for your inbox.
BETA_CONTACT_EMAIL=

# --- Cron ---
# Shared secret Vercel Cron uses to authenticate /api/cron/* Bearer calls.
# Generate with: openssl rand -base64 32
# Schedules: see vercel.json (sync every 6h; flashcards + weekly hourly).
CRON_SECRET=
